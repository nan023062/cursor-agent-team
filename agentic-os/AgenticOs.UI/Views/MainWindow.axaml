<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AgenticOs.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="AgenticOs.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Agentic OS — 运行状态"
        Width="900" Height="600">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="12,8">
            <TextBlock Text="项目根:" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding ProjectRootDisplay}" VerticalAlignment="Center" 
                       Foreground="#666" TextTrimming="CharacterEllipsis" MaxWidth="400"/>
            <Button Content="加载项目" Command="{Binding LoadProjectCommand}" Padding="12,6"/>
            <Button Content="刷新" Command="{Binding RefreshAllCommand}" Padding="12,6"/>
        </StackPanel>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" ColumnDefinitions="*,12,*" Margin="12,0">
            <!-- 调用栈 -->
            <Border Grid.Column="0" Background="#1a1a2e" CornerRadius="6" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="调用栈 (Call Stack)" 
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,12" Foreground="White"/>
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding CallStackFrames}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#16213e" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding Header}" FontWeight="Bold" Foreground="#e94560"/>
                                            <TextBlock>
                                                <Run Text="模块: " Foreground="#888"/>
                                                <Run Text="{Binding ModuleName}" Foreground="White"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding TaskDescription}" Foreground="#a0a0a0" TextWrapping="Wrap"/>
                                            <TextBlock>
                                                <Run Text="状态: " Foreground="#888"/>
                                                <Run Text="{Binding StatusText}" Foreground="#4ade80"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding SuspendReason}" 
                                                       IsVisible="{Binding SuspendReason}" Foreground="#fbbf24" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding SubTasksSummary}" 
                                                       IsVisible="{Binding SubTasksSummary}" Foreground="#94a3b8"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- 拓扑图 -->
            <Border Grid.Column="1" Background="#1a1a2e" CornerRadius="6" Padding="12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="DNA 拓扑图" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="{Binding TopologySummary}" Foreground="#94a3b8" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding TopologyNodes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#16213e" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" 
                                                       FontWeight="SemiBold" Foreground="White" Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                <TextBlock>
                                                    <Run Text="边界: " Foreground="#666"/>
                                                    <Run Text="{Binding Boundary}" Foreground="#a78bfa"/>
                                                </TextBlock>
                                                <TextBlock>
                                                    <Run Text="依赖: " Foreground="#666"/>
                                                    <Run Text="{Binding Dependencies}" Foreground="#94a3b8"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Maintainer}" 
                                                       Foreground="#64748b" FontSize="12"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="#0f0f1a" Padding="12,8">
            <TextBlock Text="{Binding StatusText}" Foreground="#94a3b8"/>
        </Border>
    </Grid>
</Window>
